{
  "id": "verify-official-result",
  "name": "Verify Official Result",
  "description": "Resolve a sports or event-result market through a constrained agent-facing tool backed by an official API blueprint.",
  "version": 1,
  "nodes": [
    {
      "id": "resolver",
      "type": "agent_loop",
      "label": "Result Resolver",
      "config": {
        "provider": "openai",
        "model": "gpt-5.4",
        "output_mode": "resolution",
        "allowed_outcomes_key": "inputs.market.outcomes_json",
        "max_steps": 5,
        "max_tool_calls": 4,
        "prompt": "Resolve this market using the verify_official_result tool. Do not fetch arbitrary sources.\n\nQuestion: {{inputs.market.question}}\nOutcomes JSON: {{inputs.market.outcomes_json}}\nGame ID: {{inputs.market.official_game_id}}\nHome team: {{inputs.market.home_team}}\nAway team: {{inputs.market.away_team}}\n\nIf the official result is not final, or the tool cannot verify the result, return inconclusive.",
        "tools": [
          {
            "name": "context_get",
            "kind": "builtin"
          },
          {
            "name": "verify_official_result",
            "kind": "blueprint",
            "description": "Verify the final score and winner from the approved official result endpoint for one game.",
            "parameters": {
              "type": "object",
              "properties": {
                "game_id": {
                  "type": "string",
                  "description": "Official game or event id."
                }
              },
              "required": ["game_id"],
              "additionalProperties": false
            },
            "input_mappings": {
              "game_id": "$args.game_id"
            },
            "timeout_seconds": 30,
            "inline": {
              "id": "verify-official-result-tool",
              "version": 1,
              "nodes": [
                {
                  "id": "status_check",
                  "type": "api_fetch",
                  "config": {
                    "url": "https://api.example.com/official-results/{{inputs.game_id}}",
                    "method": "GET",
                    "json_path": "data.status",
                    "timeout_seconds": 20
                  }
                },
                {
                  "id": "home_score",
                  "type": "api_fetch",
                  "config": {
                    "url": "https://api.example.com/official-results/{{inputs.game_id}}",
                    "method": "GET",
                    "json_path": "data.home_score",
                    "timeout_seconds": 20
                  }
                },
                {
                  "id": "away_score",
                  "type": "api_fetch",
                  "config": {
                    "url": "https://api.example.com/official-results/{{inputs.game_id}}",
                    "method": "GET",
                    "json_path": "data.away_score",
                    "timeout_seconds": 20
                  }
                },
                {
                  "id": "winner",
                  "type": "api_fetch",
                  "config": {
                    "url": "https://api.example.com/official-results/{{inputs.game_id}}",
                    "method": "GET",
                    "json_path": "data.winner",
                    "outcome_mapping": {
                      "HOME": "0",
                      "AWAY": "1",
                      "DRAW": "2"
                    },
                    "timeout_seconds": 20
                  }
                },
                {
                  "id": "summary",
                  "type": "cel_eval",
                  "config": {
                    "expressions": {
                      "final": "results.status_check.extracted == 'FINAL'",
                      "source_url": "'https://api.example.com/official-results/' + inputs.game_id"
                    }
                  }
                },
                {
                  "id": "out",
                  "type": "return",
                  "config": {
                    "value": {
                      "status": "success",
                      "final": "{{results.summary.final}}",
                      "source_url": "{{results.summary.source_url}}",
                      "outcome": "{{results.winner.outcome}}",
                      "winner": "{{results.winner.extracted}}",
                      "home_score": "{{results.home_score.extracted}}",
                      "away_score": "{{results.away_score.extracted}}",
                      "official_status": "{{results.status_check.extracted}}"
                    }
                  }
                }
              ],
              "edges": [
                { "from": "status_check", "to": "summary" },
                { "from": "home_score", "to": "summary" },
                { "from": "away_score", "to": "summary" },
                { "from": "winner", "to": "summary" },
                { "from": "summary", "to": "out" }
              ],
              "budget": {
                "max_total_time_seconds": 30
              }
            }
          }
        ]
      }
    },
    {
      "id": "submit",
      "type": "return",
      "label": "Submit Official Result",
      "config": {
        "value": {
          "status": "success",
          "outcome": "{{results.resolver.outcome}}",
          "confidence": "{{results.resolver.confidence}}",
          "reasoning": "{{results.resolver.reasoning}}"
        }
      }
    },
    {
      "id": "cancel",
      "type": "return",
      "label": "Cancel",
      "config": {
        "value": {
          "status": "cancelled",
          "reason": "The official result tool did not produce a final verified outcome."
        }
      }
    }
  ],
  "edges": [
    {
      "from": "resolver",
      "to": "submit",
      "condition": "results.resolver.status == 'success' && results.resolver.outcome != 'inconclusive' && results.resolver.outcome != ''"
    },
    {
      "from": "resolver",
      "to": "cancel",
      "condition": "results.resolver.outcome == 'inconclusive' || results.resolver.status != 'success'"
    }
  ],
  "budget": {
    "max_total_time_seconds": 1800,
    "max_total_tokens": 60000
  }
}
