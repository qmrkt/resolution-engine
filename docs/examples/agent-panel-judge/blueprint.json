{
  "id": "agent-panel-judge",
  "name": "Agent Panel Judge",
  "description": "Separate specialist agents prepare rule analysis, evidence, and skeptical review before a final judge resolves the market.",
  "version": 1,
  "nodes": [
    {
      "id": "rules_agent",
      "type": "agent_loop",
      "label": "Rules Agent",
      "config": {
        "provider": "openai",
        "model": "gpt-5.4-mini",
        "output_mode": "structured",
        "max_steps": 4,
        "max_tool_calls": 4,
        "prompt": "Analyze the market wording and resolution rules. Identify what facts are needed, what would make the market unanswerable, and which outcome labels are valid.\n\nQuestion: {{inputs.market.question}}\nRules: {{inputs.market.resolution_rules}}\nOutcomes JSON: {{inputs.market.outcomes_json}}",
        "output_tool": {
          "parameters": {
            "type": "object",
            "properties": {
              "answerability": { "type": "string" },
              "required_facts": { "type": "array", "items": { "type": "string" } },
              "ambiguities": { "type": "array", "items": { "type": "string" } }
            },
            "required": ["answerability", "required_facts", "ambiguities"],
            "additionalProperties": false
          }
        }
      }
    },
    {
      "id": "evidence_agent",
      "type": "agent_loop",
      "label": "Evidence Agent",
      "config": {
        "provider": "anthropic",
        "model": "claude-sonnet-4-6",
        "output_mode": "structured",
        "max_steps": 7,
        "max_tool_calls": 12,
        "prompt": "Gather and summarize evidence relevant to this market.\n\nQuestion: {{inputs.market.question}}\nOutcomes JSON: {{inputs.market.outcomes_json}}\nSuggested sources JSON: {{inputs.market.sources_json}}",
        "tools": [
          { "name": "source_fetch", "kind": "builtin" },
          { "name": "json_extract", "kind": "builtin" },
          { "name": "context_get", "kind": "builtin" }
        ],
        "output_tool": {
          "parameters": {
            "type": "object",
            "properties": {
              "evidence_summary": { "type": "string" },
              "citations": { "type": "array", "items": { "type": "string" } },
              "suggested_outcome": { "type": "integer" },
              "confidence": { "type": "string", "enum": ["high", "medium", "low"] }
            },
            "required": ["evidence_summary", "citations", "suggested_outcome", "confidence"],
            "additionalProperties": false
          }
        }
      }
    },
    {
      "id": "skeptic_agent",
      "type": "agent_loop",
      "label": "Skeptic Agent",
      "config": {
        "provider": "google",
        "model": "gemini-3.1-pro-preview",
        "output_mode": "structured",
        "max_steps": 4,
        "max_tool_calls": 4,
        "prompt": "Review the rule analysis and evidence for reasons not to resolve yet.\n\nRules report JSON: {{results.rules_agent.output_json}}\nEvidence report JSON: {{results.evidence_agent.output_json}}\n\nIdentify conflicts, missing primary evidence, alternate outcome interpretations, and cancellation risks.",
        "output_tool": {
          "parameters": {
            "type": "object",
            "properties": {
              "blocking_issues": { "type": "array", "items": { "type": "string" } },
              "risk_level": { "type": "string", "enum": ["high", "medium", "low"] },
              "recommendation": { "type": "string" }
            },
            "required": ["blocking_issues", "risk_level", "recommendation"],
            "additionalProperties": false
          }
        }
      }
    },
    {
      "id": "judge_agent",
      "type": "agent_loop",
      "label": "Final Judge",
      "config": {
        "provider": "openai",
        "model": "gpt-5.4",
        "output_mode": "resolution",
        "allowed_outcomes_key": "inputs.market.outcomes_json",
        "reasoning": "medium",
        "max_steps": 5,
        "max_tool_calls": 4,
        "prompt": "Make the final resolution decision using the panel reports.\n\nQuestion: {{inputs.market.question}}\nOutcomes JSON: {{inputs.market.outcomes_json}}\nRules report JSON: {{results.rules_agent.output_json}}\nEvidence report JSON: {{results.evidence_agent.output_json}}\nSkeptic report JSON: {{results.skeptic_agent.output_json}}\n\nResolve only if evidence and rules support one outcome. If unresolved or materially ambiguous, return inconclusive."
      }
    },
    {
      "id": "submit",
      "type": "return",
      "label": "Submit",
      "config": {
        "value": {
          "status": "success",
          "outcome": "{{results.judge_agent.outcome}}",
          "confidence": "{{results.judge_agent.confidence}}",
          "reasoning": "{{results.judge_agent.reasoning}}"
        }
      }
    },
    {
      "id": "cancel",
      "type": "return",
      "label": "Cancel",
      "config": {
        "value": {
          "status": "cancelled",
          "reason": "The agent panel judge was inconclusive."
        }
      }
    }
  ],
  "edges": [
    { "from": "rules_agent", "to": "skeptic_agent" },
    { "from": "evidence_agent", "to": "skeptic_agent" },
    { "from": "skeptic_agent", "to": "judge_agent" },
    {
      "from": "judge_agent",
      "to": "submit",
      "condition": "results.judge_agent.status == 'success' && results.judge_agent.outcome != 'inconclusive' && results.judge_agent.outcome != ''"
    },
    {
      "from": "judge_agent",
      "to": "cancel",
      "condition": "results.judge_agent.outcome == 'inconclusive' || results.judge_agent.status != 'success'"
    }
  ],
  "budget": {
    "max_total_time_seconds": 2400,
    "max_total_tokens": 180000
  }
}
