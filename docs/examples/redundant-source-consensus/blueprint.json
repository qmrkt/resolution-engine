{
  "id": "redundant-source-consensus",
  "name": "Redundant Source Consensus",
  "description": "Fetch multiple configured sources, let an agent compare them, and resolve only when the evidence is coherent.",
  "version": 1,
  "nodes": [
    {
      "id": "fetch_sources",
      "type": "map",
      "label": "Fetch Sources",
      "config": {
        "items_key": "inputs.market.sources_json",
        "batch_size": 1,
        "max_concurrency": 4,
        "on_error": "continue",
        "inline": {
          "id": "fetch-one-source",
          "version": 1,
          "nodes": [
            {
              "id": "fetch",
              "type": "api_fetch",
              "config": {
                "url": "{{inputs.source_url}}",
                "method": "GET",
                "json_path": "data.outcome",
                "outcome_mapping": {
                  "YES": "0",
                  "NO": "1"
                },
                "timeout_seconds": 20
              }
            },
            {
              "id": "out",
              "type": "return",
              "config": {
                "value": {
                  "status": "{{results.fetch.status}}",
                  "outcome": "{{results.fetch.outcome}}",
                  "extracted": "{{results.fetch.extracted}}",
                  "raw": "{{results.fetch.raw}}"
                }
              }
            }
          ],
          "edges": [
            { "from": "fetch", "to": "out" }
          ]
        },
        "input_mappings": {
          "source_url": "inputs.market.source_url"
        }
      }
    },
    {
      "id": "consensus",
      "type": "agent_loop",
      "label": "Consensus Judge",
      "config": {
        "provider": "openai",
        "model": "gpt-5.4",
        "output_mode": "resolution",
        "allowed_outcomes_key": "inputs.market.outcomes_json",
        "max_steps": 4,
        "max_tool_calls": 6,
        "prompt": "Resolve this prediction market only if the fetched sources are mutually consistent.\n\nQuestion: {{inputs.market.question}}\nOutcomes JSON: {{inputs.market.outcomes_json}}\nSource fetch results JSON: {{results.fetch_sources.results_json}}\n\nIf sources conflict, are missing, or do not support any outcome, return inconclusive.",
        "tools": [
          {
            "name": "context_get",
            "kind": "builtin"
          },
          {
            "name": "json_extract",
            "kind": "builtin"
          }
        ]
      }
    },
    {
      "id": "submit",
      "type": "return",
      "label": "Submit Consensus",
      "config": {
        "value": {
          "status": "success",
          "outcome": "{{results.consensus.outcome}}",
          "confidence": "{{results.consensus.confidence}}",
          "reasoning": "{{results.consensus.reasoning}}"
        }
      }
    },
    {
      "id": "cancel",
      "type": "return",
      "label": "Cancel",
      "config": {
        "value": {
          "status": "cancelled",
          "reason": "Configured sources did not reach a coherent outcome."
        }
      }
    }
  ],
  "edges": [
    {
      "from": "fetch_sources",
      "to": "consensus",
      "condition": "results.fetch_sources.status == 'success'"
    },
    {
      "from": "consensus",
      "to": "submit",
      "condition": "results.consensus.status == 'success' && results.consensus.outcome != 'inconclusive' && results.consensus.outcome != ''"
    },
    {
      "from": "consensus",
      "to": "cancel",
      "condition": "results.consensus.outcome == 'inconclusive' || results.consensus.status != 'success'"
    }
  ],
  "budget": {
    "max_total_time_seconds": 2400,
    "max_total_tokens": 80000
  }
}
